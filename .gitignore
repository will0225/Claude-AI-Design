# Secrets — never commit real API keys or client brand config
.env
.env.local
.env.*.local
brand/brand.config.yaml

# Style guide renders (generated from PDF for extraction)
brand/style-guide-page-*.png

# Generated documents
brand/output/*.html

# Client inbox downloads (keep folder structure)
brand/inbox/*
!brand/inbox/README.txt
!brand/inbox/.gitkeep
!brand/inbox/done/
brand/inbox/done/*
!brand/inbox/done/.gitkeep

# Python
__pycache__/
*.py[cod]
.venv/
venv/
*.egg-info/
dist/
build/

# Node
node_modules/
npm-debug.log*
yarn-error.log*

# OS / editor
.DS_Store
Thumbs.db
.idea/
.vscode/
*.swp
