{
  "name": "claude-demo-node",
  "version": "1.0.0",
  "description": "Minimal Claude API demo (Node.js)",
  "type": "module",
  "scripts": {
    "demo": "node claude_demo.js",
    "demo:all": "node claude_demo.js --all",
    "make:proposal": "node make.js proposal",
    "make:report": "node make.js report",
    "generate:proposal": "node generate_document.js proposal --input ../brand/samples/proposal-notes.txt",
    "generate:report": "node generate_document.js report --input ../brand/samples/report-notes.txt",
    "brand": "node generate_document.js --show-brand"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.52.0",
    "dotenv": "^16.4.0",
    "js-yaml": "^4.1.0"
  }
}
